{
  "name": "@utilitywarehouse/hearth-react-native-icons",
  "version": "0.8.5",
  "description": "Hearth React Native Icons",
  "author": "Design Systems <design-systems@uw.co.uk>",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "clean:lib": "rm -rf lib && rm -rf figma-code-connect",
    "clean:dist": "rm -rf dist",
    "clean": "rm -rf node_modules",
    "transform": "svgr --config-file ./svgr.config.cjs --template templates/icon.cjs ../svg-icons/lib",
    "copy-types": "cp ./templates/props.tsx ./lib/types.tsx",
    "format": "prettier --log-level=silent --write --parser=typescript \"lib/*.ts*\"",
    "generate": "pnpm clean:lib && pnpm transform && pnpm copy-types && node ./scripts/generate-figma-code-connect.cjs",
    "lint:fix": "TIMING=1 eslint --fix --max-warnings 0",
    "lint": "TIMING=1 eslint --max-warnings 0",
    "build": "pnpm clean:dist && tsc --build ./tsconfig.build.json",
    "figma:publish": "figma connect publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18.1.0 || ^19.0.0",
    "react-native": ">=0.70.6",
    "react-native-svg": ">=12.3.0"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.3.11",
    "@svgr/cli": "^7.0.0",
    "@tsconfig/react-native": "^3.0.0",
    "@types/jest": "^29.5.1",
    "@types/react": "^19.1.10",
    "@types/react-native": "^0.72.0",
    "fs-extra": "^11.1.1",
    "lodash.template": "^4.18.1",
    "react-native-svg": "^15.12.1",
    "typescript": "^5.5.3"
  },
  "files": [
    "dist"
  ]
}
