{
  "name": "@utilitywarehouse/hearth-css-reset",
  "version": "0.1.5",
  "description": "A bare-bones CSS reset for UW web development",
  "license": "Apache-2.0",
  "main": "./index.css",
  "exports": {
    ".": "./index.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utilitywarehouse/hearth.git"
  },
  "scripts": {
    "build": "postcss src --dir .",
    "dev": "postcss --watch --verbose src --dir .",
    "clean": "rm -f index.css && rm -rf node_modules",
    "format": "prettier --write --parser=scss \"src/index.css\"",
    "format:ci": "prettier --list-different --parser=scss \"src/index.css\""
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "cssnano": "^5.1.13",
    "postcss": "^8.4.16",
    "postcss-cli": "^10.0.0"
  },
  "files": [
    "README.md",
    "index.css"
  ]
}
