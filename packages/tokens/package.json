{
  "name": "@utilitywarehouse/hearth-tokens",
  "version": "0.1.0",
  "description": "",
  "style": "./index.css",
  "main": "./js/index.js",
  "type": "module",
  "scripts": {
    "build:css": "postcss css/index.css --dir .",
    "build:js": "tsc --project ./tsconfig.json",
    "build:browser": "tsc --project ./tsconfig.browser.json",
    "generate:tokens": "node ./scripts/generate-tokens.js",
    "build": "pnpm clean:build && pnpm generate:tokens && pnpm build:css && pnpm build:js && pnpm build:browser && pnpm format",
    "clean": "rm -rf node_modules .turbo",
    "clean:build": "rm -rf src css js browser",
    "lint:css": "stylelint \"./**/*.css\" --fix",
    "format": "prettier --write \"./**/*.{ts,js}\" && pnpm lint:css"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/lodash.merge": "^4.6.9",
    "cssnano": "^5.1.15",
    "lodash.merge": "^4.6.2",
    "postcss": "^8.4.49",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^15.1.0",
    "style-dictionary": "^4.2.0",
    "stylelint": "^16.10.0",
    "typescript": "^5.6.3"
  },
  "files": [
    "js/**",
    "css/**",
    "browser/**",
    "index.css"
  ]
}
