{
  "name": "@utilitywarehouse/hearth-tokens",
  "version": "0.4.2",
  "description": "",
  "style": "./index.css",
  "main": "./js/index.js",
  "type": "module",
  "exports": {
    ".": "./js/index.js",
    "./browser": "./browser/index.js",
    "./browser/*": "./browser/*",
    "./js": "./js/index.js",
    "./js/*": "./js/*",
    "./css": "./css/index.css",
    "./css/*": "./css/*",
    "./index.css": "./index.css",
    "./*": "./*"
  },
  "scripts": {
    "build:css": "postcss css/index.css --dir .",
    "build:js": "tsc --project ./tsconfig.json",
    "build:browser": "tsc --project ./tsconfig.browser.json",
    "typecheck": "tsc --noEmit --project ./tsconfig.json && tsc --noEmit --project ./tsconfig.browser.json",
    "build:tokens": "turbo run build:css build:js build:browser && pnpm format",
    "generate:tokens": "node ./scripts/generate-tokens.js",
    "clean": "rm -rf node_modules .turbo",
    "clean:build": "rm -rf src css js browser",
    "lint:css": "stylelint \"./css/*.css\" --fix",
    "format": "prettier --write \"./**/*.{ts,js,css}\" \"!./index.css\"",
    "lint:fix": "pnpm run lint:css && pnpm run format"
  },
  "keywords": [],
  "author": "Design Systems <design-systems@uw.co.uk>",
  "license": "Apache-2.0",
  "prettier": "@utilitywarehouse/prettier-config",
  "devDependencies": {
    "@types/lodash.merge": "^4.6.9",
    "cssnano": "^5.1.15",
    "lodash.merge": "^4.6.2",
    "postcss": "^8.4.49",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^15.1.0",
    "style-dictionary": "^4.2.0",
    "stylelint": "^16.10.0"
  },
  "files": [
    "js/**",
    "css/**",
    "browser/**",
    "index.css"
  ]
}
