{
  "name": "@utilitywarehouse/hearth-react",
  "version": "0.4.1",
  "description": "React components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./styles.css",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": "./*"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "clean": "rm -rf .turbo node_modules dist *.css",
    "build": "pnpm build:css && pnpm build:js",
    "build:css": "postcss ./src/styles/index.css -o styles.css",
    "build:js": "NODE_OPTIONS='--max-old-space-size=16384' tsup",
    "dev:js": "NODE_OPTIONS='--max-old-space-size=16384' tsup --watch",
    "dev:css": "postcss --watch --verbose src/styles/index.css -o styles.css",
    "dev": "pnpm run \"/^dev:.*/\"",
    "ts-types": "tsc",
    "lint": "pnpm lint:js && pnpm lint:css",
    "lint:fix": "pnpm lint:js:fix && pnpm lint:css:fix",
    "lint:js": "TIMING=1 eslint --max-warnings 0 \"src/**/*.ts*\" --ignore-pattern '*.ignore.*'",
    "lint:js:fix": "TIMING=1 eslint --fix --max-warnings 0 \"src/**/*.ts*\" src --ignore-pattern '*.ignore.*'",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write \"src/**/*.ts*\"",
    "format:ci": "prettier --list-different \"src/**/*.ts*\"",
    "copy-tokens-index": "cp ./src/styles/tokens.css ./src/styles/tokens/index.css",
    "gen:color-tokens": "node ./scripts/generate-color-tokens.js && prettier --write \"./src/tokens/color.ts\""
  },
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist/**",
    "*.css"
  ],
  "peerDependencies": {
    "@utilitywarehouse/hearth-fonts": "workspace:*",
    "@utilitywarehouse/hearth-react-icons": "workspace:*",
    "react": "^18.0.0 || ^19.0.0 ",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@radix-ui/react-use-controllable-state": "^1.0.1",
    "@utilitywarehouse/hearth-css-reset": "workspace:*",
    "clsx": "^2.1.1",
    "radix-ui": "^1.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@utilitywarehouse/hearth-react-icons": "workspace:*",
    "autoprefixer": "^10.4.20",
    "cssnano": "^7.0.6",
    "ejs": "^3.1.10",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "postcss-custom-media": "^11.0.5",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.1",
    "prop-types": "^15.8.1",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-media-use-custom-media": "^4.0.0",
    "tsup": "^8.3.5"
  }
}
