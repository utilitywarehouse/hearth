{
  "name": "@utilitywarehouse/hearth-react",
  "version": "0.30.3",
  "description": "React components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./styles.css",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": "./*"
  },
  "sideEffects": [
    "*.css"
  ],
  "bin": {
    "hearth-react": "./scripts/init-ai.js"
  },
  "scripts": {
    "clean": "rm -rf .turbo node_modules dist *.css storybook-static",
    "build": "pnpm build:css && pnpm build:js",
    "copy:breakpoints": "cp ./src/styles/breakpoints.css ./breakpoints.css",
    "copy:tokens": "rm -rf ./src/styles/tokens && mkdir -p ./src/styles/tokens && cp -r ../tokens/css/* ./src/styles/tokens && pnpm run copy:tokens:index",
    "copy:tokens:index": "cp ./src/styles/tokens.css ./src/styles/tokens/index.css",
    "build:css": "postcss ./src/styles/index.css -o styles.css && pnpm copy:breakpoints",
    "build:js": "NODE_OPTIONS='--max-old-space-size=6144' tsup && tsc -p tsconfig.build.json",
    "dev:js": "NODE_OPTIONS='--max-old-space-size=16384' tsup --watch",
    "dev:css": "postcss --watch --verbose src/styles/index.css -o styles.css",
    "dev:storybook": "storybook dev -p 6007",
    "dev": "pnpm run \"/^dev:.*/\"",
    "ts-types": "tsc",
    "lint": "turbo run lint:js lint:css",
    "lint:fix": "turbo run lint:js:fix lint:css:fix",
    "lint:js": "TIMING=1 eslint --max-warnings 0 \"src/**/*.ts*\"",
    "lint:js:fix": "TIMING=1 eslint --fix --max-warnings 0 \"src/**/*.{js,ts*}\"",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write \"{src,public,docs,scripts}/**/*.{js,ts*,md*,css}\" {README,SKILL}.md",
    "format:ci": "prettier --list-different \"src/**/*.{ts*,mdx,css}\"",
    "figma:publish": "figma connect publish",
    "build:storybook": "pnpm generate:llm-docs && storybook build",
    "generate:llm-docs": "rm -rf public && node scripts/generate-llm-docs.js && prettier --write \"public/**/*.md\"",
    "copy:changelog": "node ./scripts/copy-changelog.js",
    "test:storybook": "vitest run --project=storybook"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist/**",
    "*.css",
    "SKILL.md",
    "public/llms/**",
    "public/llms.txt"
  ],
  "peerDependencies": {
    "@utilitywarehouse/hearth-fonts": "workspace:*",
    "@utilitywarehouse/hearth-react-icons": "0.8.0",
    "react": "^18.0.0 || ^19.0.0 ",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@base-ui/utils": "^0.2.4",
    "@floating-ui/dom": "^1.7.4",
    "@radix-ui/react-use-controllable-state": "^1.0.1",
    "@utilitywarehouse/hearth-css-reset": "workspace:*",
    "radix-ui": "^1.4.3",
    "react-datepicker": "^8.9.0"
  },
  "devDependencies": {
    "@utilitywarehouse/hearth-storybook-utils": "workspace:*",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/react-vite": "^10.3.6",
    "@tanstack/react-virtual": "^3.13.13",
    "@types/node": "^22.9.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.6",
    "@types/seedrandom": "^3.0.8",
    "@utilitywarehouse/hearth-fonts": "workspace:*",
    "@utilitywarehouse/hearth-react-icons": "workspace:*",
    "@utilitywarehouse/hearth-svg-assets": "workspace:*",
    "@utilitywarehouse/hearth-tokens": "workspace:*",
    "@vitest/browser-playwright": "^4.1.7",
    "autoprefixer": "^10.4.20",
    "browserslist": "^4.28.1",
    "cssnano": "^7.0.6",
    "ejs": "^3.1.10",
    "globals": "^15.14.0",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "postcss-cli": "^11.0.0",
    "postcss-custom-media": "^11.0.5",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.1",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.70.0",
    "react-docgen-typescript": "^2.2.2",
    "remark-gfm": "^4.0.1",
    "seedrandom": "^3.0.5",
    "storybook": "^10.4.1",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1",
    "stylelint-media-use-custom-media": "^4.0.0",
    "stylelint-value-no-unknown-custom-properties": "^6.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "vitest": "^4.1.7"
  }
}
