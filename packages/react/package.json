{
  "name": "@utilitywarehouse/pollen-react",
  "version": "0.0.0",
  "description": "React components",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf node_modules && rm -rf dist",
    "build": "NODE_OPTIONS='--max-old-space-size=16384' tsup",
    "ts-types": "tsc",
    "lint:fix": "TIMING=1 eslint --fix --max-warnings 0 --ext ts,tsx src",
    "lint": "TIMING=1 eslint --max-warnings 0 --ext ts,tsx src",
    "format": "prettier --write \"./src/**/*.{ts,tsx}\"",
    "format:ci": "prettier --list-different \"./{src,types}/**/*.{tsx,ts}\"",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0"
  },
  "dependencies": {
    "@utilitywarehouse/colour-system": "^0.5.0",
    "@utilitywarehouse/react-icons": "^1.11.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.2",
    "@storybook/addon-essentials": "^8.4.2",
    "@storybook/addon-interactions": "^8.4.2",
    "@storybook/addon-onboarding": "^8.4.2",
    "@storybook/blocks": "^8.4.2",
    "@storybook/react": "^8.4.2",
    "@storybook/react-vite": "^8.4.2",
    "@storybook/test": "^8.4.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@utilitywarehouse/css-reset": "^0.1.0",
    "@utilitywarehouse/fontsource": "^0.1.0",
    "eslint-plugin-storybook": "^0.11.0",
    "prop-types": "^15.8.1",
    "react": "^17.0.0 || ^18.0.0",
    "react-dom": "^17.0.0 || ^18.0.0",
    "storybook": "^8.4.2",
    "tsup": "^8.3.5"
  }
}
