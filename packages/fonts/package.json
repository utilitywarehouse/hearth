{
  "name": "@utilitywarehouse/hearth-fonts",
  "version": "0.0.4",
  "description": "Fonts for the UW Hearth Design System",
  "main": "index.css",
  "type": "commonjs",
  "author": "Rob Phoenix <rphoenix@uw.co.uk>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utilitywarehouse/hearth.git",
    "directory": "packages/fonts"
  },
  "scripts": {
    "build": "postcss src --dir .",
    "dev": "postcss --watch --verbose src --dir .",
    "clean": "rm -rf *.css node_modules .turbo"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "devDependencies": {
    "cssnano": "^5.1.15",
    "postcss": "^8.5.10",
    "postcss-cli": "^10.1.0",
    "postcss-import": "^15.1.0"
  },
  "files": [
    "README.md",
    "*.css",
    "files"
  ]
}
