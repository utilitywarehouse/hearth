{
  "name": "@utilitywarehouse/hearth-react-native",
  "version": "0.35.0",
  "description": "Utility Warehouse React Native UI library",
  "license": "Apache-2.0",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "module": "build/index",
  "type": "module",
  "sideEffects": false,
  "bin": {
    "hearth-react-native": "./scripts/init-ai.js"
  },
  "files": [
    "build/**",
    "scripts/init-ai.js",
    "SKILL.md",
    "public/llms/**",
    "public/llms.txt"
  ],
  "scripts": {
    "clean": "rm -rf node_modules build .turbo",
    "generateColours": "node ./scripts/generateColours.js",
    "copyTokens": "node ./scripts/copyTokens.js",
    "copy:changelog": "node ./scripts/copyChangelog.js",
    "generate:llm-docs": "rm -rf public && node scripts/generate-llm-docs.js && prettier --write \"public/**/*.md\"",
    "lint:fix": "TIMING=1 eslint --fix .",
    "lint": "TIMING=1 eslint .",
    "build": "tsc",
    "watch": "tsc --watch",
    "figma:create": "figma connect create",
    "figma:publish": "figma connect publish",
    "test": "vitest run --config vitest.unit.config.ts",
    "test:storybook": "vitest run --project storybook",
    "dev": "storybook dev -p 6006",
    "dev:docs": "storybook dev -p 6002 --no-open",
    "build:storybook": "storybook build",
    "build:storybook:docs": "storybook build --docs"
  },
  "dependencies": {
    "@gluestack-ui/accordion": "1.0.14",
    "@gluestack-ui/alert": "0.1.15",
    "@gluestack-ui/button": "1.0.7",
    "@gluestack-ui/checkbox": "0.1.32",
    "@gluestack-ui/form-control": "0.1.19",
    "@gluestack-ui/icon": "0.1.22",
    "@gluestack-ui/input": "0.1.31",
    "@gluestack-ui/link": "0.1.22",
    "@gluestack-ui/pressable": "0.1.16",
    "@gluestack-ui/radio": "0.1.33",
    "@gluestack-ui/spinner": "0.1.14",
    "@gluestack-ui/switch": "0.1.22",
    "@gluestack-ui/textarea": "0.1.23",
    "@quidone/react-native-wheel-picker": "^1.6.1",
    "@react-stately/utils": "^3.12.1",
    "dayjs": "^1.11.13",
    "nanoid": "3.3.11"
  },
  "devDependencies": {
    "@utilitywarehouse/hearth-storybook-utils": "workspace:*",
    "@babel/plugin-proposal-export-namespace-from": "^7.18.9",
    "@gorhom/bottom-sheet": "5.2.6",
    "@storybook/addon-a11y": "^10.2.1",
    "@storybook/addon-docs": "^10.2.1",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.2.1",
    "@storybook/react-native-web-vite": "^10.2.1",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.6",
    "@types/react-native": "^0.72.8",
    "@utilitywarehouse/hearth-fonts": "workspace:^",
    "@utilitywarehouse/hearth-react-icons": "workspace:^",
    "@utilitywarehouse/hearth-react-native-icons": "workspace:^",
    "@utilitywarehouse/hearth-svg-assets": "workspace:^",
    "@utilitywarehouse/hearth-tokens": "workspace:^",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "globals": "^15.15.0",
    "playwright": "^1.59.1",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.80.0",
    "react-native-edge-to-edge": "1.6.1",
    "react-native-gesture-handler": "2.28.0",
    "react-native-nitro-modules": "0.31.4",
    "react-native-reanimated": "4.1.3",
    "react-native-safe-area-context": "5.6.1",
    "react-native-svg": "^15.12.1",
    "react-native-unistyles": "3.0.17",
    "react-native-web": "^0.20.0",
    "react-native-worklets": "^0.5.1",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.4.1",
    "vite": "^7.1.3",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "@gorhom/bottom-sheet": ">=5.0.0",
    "@utilitywarehouse/hearth-react-native-icons": ">=0.8.0",
    "react": ">=17 || ^18.x || ^19.x",
    "react-native": ">=0.77",
    "react-native-gesture-handler": ">=2",
    "react-native-reanimated": "3.x || ^4.x",
    "react-native-safe-area-context": "5.x",
    "react-native-svg": ">=13.4.0",
    "react-native-unistyles": ">=3.0.0",
    "react-native-web": ">=0.19"
  }
}
