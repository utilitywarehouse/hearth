{
  "name": "@utilitywarehouse/hearth-react-icons",
  "version": "0.7.3",
  "description": "Hearth React icons",
  "author": "Rob Phoenix",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf node_modules && rm -rf dist",
    "clean:lib": "rm -rf lib",
    "transform": "svgr --config-file ./svgr.config.cjs --template templates/icon.cjs --index-template templates/index.cjs ../svg-icons/lib",
    "copy-types": "cp ./templates/props.tsx ./lib/types.tsx",
    "format": "prettier --log-level=silent --write --parser=typescript \"lib/*.ts*\"",
    "generate": "pnpm clean:lib && pnpm transform && pnpm copy-types && node ./scripts/generate-manifest.cjs && node ./scripts/generate-figma-code-connect.cjs",
    "build": "tsup",
    "ts-types": "tsc",
    "lint:fix": "TIMING=1 eslint --fix --ext ts,tsx lib",
    "lint": "TIMING=1 eslint --ext ts,tsx lib",
    "figma:publish": "figma connect publish"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0 "
  },
  "devDependencies": {
    "@figma/code-connect": "^1.1.3",
    "@svgr/cli": "^7.0.0",
    "@svgr/plugin-jsx": "^7.0.0",
    "@svgr/plugin-svgo": "^7.0.0",
    "@types/react": "^18.0.35",
    "chromatic": "^7.2.0",
    "fs-extra": "^11.1.1",
    "lodash.template": "^4.5.0",
    "tsup": "^6.7.0",
    "typescript": "^5.5.3"
  },
  "files": [
    "dist"
  ]
}
