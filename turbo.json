{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "build": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.stories.{tsx,jsx,mdx}"],
      "outputs": ["dist/**", "build/**", "storybook-static/**", "*.css"],
      "dependsOn": ["^build"]
    },
    "build:react": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.stories.{tsx,jsx,mdx}"],
      "outputs": ["dist/**", "build/**", "storybook-static/**", "*.css"],
      "dependsOn": ["^build:react"]
    },
    "build:icons": {
      "outputs": ["dist/**"]
    },
    "checks": {
      "outputs": []
    },
    "checks:ci": {
      "outputs": []
    },
    "checks:build": {
      "outputs": ["dist/**"]
    },
    "format": {
      "dependsOn": ["^format"],
      "outputs": []
    },
    "format:ci": {
      "dependsOn": ["^format:ci"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "ios": {
      "cache": false,
      "persistent": true
    },
    "android": {
      "cache": false,
      "persistent": true
    },
    "prebuild": {
      "cache": true,
      "persistent": true
    },
    "watch": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false,
      "persistent": true
    },
    "dev:docs": {
      "cache": false
    },
    "build:storybook": {
      "outputs": ["storybook-static/**"],
      "dependsOn": ["^build"]
    },
    "build:storybook:docs": {
      "outputs": ["storybook-static/**"],
      "dependsOn": ["^build"]
    },
    "build:storybook:react": {
      "outputs": ["storybook-static/**"],
      "dependsOn": ["^build:react"]
    },
    "generate": {
      "cache": false
    },
    "generate:icons": {
      "cache": false
    },
    "generate:svg-icons": {
      "cache": false
    },
    "generate:assets": {
      "cache": false
    },
    "generate:svg-assets": {
      "cache": false
    },
    "generate:react": {
      "cache": false
    },
    "generate:storybook": {
      "cache": false
    },
    "copy-tokens-index": {
      "cache": false
    },
    "gen:color-tokens": {
      "cache": false
    }
  }
}
