{
  "name": "storybook-icons",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "storybook dev --quiet -p 6006",
    "dev:docs": "storybook dev -p 6004 --no-open",
    "format": "prettier --log-level=silent --write --parser=typescript \"utils/*.ts*\"",
    "generate": "node './scripts/generate-icons-utils.js'",
    "lint": "eslint .",
    "clean": "rm -rf node_modules storybook-static .turbo",
    "build:storybook": "storybook build",
    "build:storybook:docs": "storybook build --docs"
  },
  "dependencies": {
    "@utilitywarehouse/hearth-css-reset": "workspace:*",
    "@utilitywarehouse/hearth-fonts": "workspace:*",
    "@utilitywarehouse/hearth-react": "workspace:*",
    "@utilitywarehouse/hearth-react-icons": "workspace:*",
    "@utilitywarehouse/hearth-tokens": "workspace:*",
    "ejs": "^3.1.9",
    "fs-extra": "^11.1.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-docs": "^10.2.1",
    "@storybook/addon-onboarding": "^10.2.1",
    "@storybook/react-vite": "^10.2.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.3.4",
    "globals": "^15.14.0",
    "storybook": "^10.4.1",
    "typescript": "~5.6.2",
    "vite": "^6.4.1"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
