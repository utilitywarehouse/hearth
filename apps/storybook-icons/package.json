{
  "name": "storybook-icons",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "storybook dev --quiet -p 6006",
    "format": "prettier --log-level=silent --write --parser=typescript \"utils/*.ts*\"",
    "generate": "node './scripts/generate-icons-utils.js'",
    "dev:vite": "vite",
    "build:vite": "tsc -b && vite build",
    "lint": "eslint .",
    "clean": "rm -rf node_modules storybook-static .turbo",
    "build:storybook": "storybook build"
  },
  "dependencies": {
    "@utilitywarehouse/hearth-css-reset": "workspace:*",
    "@utilitywarehouse/hearth-fonts": "workspace:*",
    "@utilitywarehouse/hearth-react": "workspace:*",
    "@utilitywarehouse/hearth-react-icons": "workspace:*",
    "@utilitywarehouse/hearth-tokens": "workspace:*",
    "ejs": "^3.1.9",
    "fs-extra": "^11.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.4",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/addon-mdx-gfm": "^8.4.5",
    "@storybook/addon-onboarding": "^8.6.12",
    "@storybook/blocks": "^8.6.12",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@utilitywarehouse/web-ui": "^1.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint-plugin-storybook": "^0.11.0",
    "globals": "^15.14.0",
    "storybook": "^8.6.12",
    "typescript": "~5.6.2",
    "vite": "^6.0.5"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
