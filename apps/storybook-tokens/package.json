{
  "name": "storybook-tokens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preview": "vite preview",
    "clean": "rm -rf node_modules storybook-static .turbo",
    "dev": "storybook dev -p 6006",
    "dev:docs": "storybook dev -p 6003 --no-open",
    "build:storybook": "storybook build",
    "build:storybook:docs": "storybook build --docs"
  },
  "dependencies": {
    "@utilitywarehouse/hearth-css-reset": "workspace:*",
    "@utilitywarehouse/hearth-fonts": "workspace:*",
    "@utilitywarehouse/hearth-tokens": "workspace:*",
    "@utilitywarehouse/hearth-react": "workspace:*",
    "@utilitywarehouse/hearth-react-icons": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-docs": "10.2.1",
    "@storybook/addon-onboarding": "10.2.1",
    "@storybook/react-vite": "10.2.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.3.4",
    "globals": "^15.14.0",
    "remark-gfm": "^4.0.1",
    "storybook": "10.2.10",
    "typescript": "~5.6.2",
    "vite": "^6.4.2"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
