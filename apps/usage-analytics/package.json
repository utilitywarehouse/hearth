{
  "name": "usage-analytics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Org-wide usage analytics dashboard for @utilitywarehouse/hearth-* packages.",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "pnpm run copy-data && vite",
    "build": "pnpm run copy-data && pnpm run typecheck && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "preview": "vite preview",
    "copy-data": "node ./scripts/copy-data.js",
    "clear-data": "node ./scripts/clear-data.js",
    "collect": "tsx collector/index.ts",
    "gen:manifests": "tsx collector/parse/build-manifests.ts",
    "gen:sample": "tsx scripts/gen-sample-data.ts",
    "test": "tsx --test collector/**/*.test.ts",
    "lint": "eslint .",
    "clean": "rm -rf node_modules dist .turbo public/data"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.13",
    "@utilitywarehouse/hearth-fonts": "workspace:*",
    "@utilitywarehouse/hearth-react": "workspace:*",
    "@utilitywarehouse/hearth-react-icons": "workspace:^0.9.0",
    "@utilitywarehouse/hearth-tokens": "workspace:*",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@babel/types": "^7.26.0",
    "@octokit/plugin-retry": "^7.1.2",
    "@octokit/plugin-throttling": "^9.3.2",
    "@octokit/rest": "^21.0.2",
    "@types/babel__traverse": "^7.20.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.2",
    "tsx": "^4.19.2",
    "typescript": "~6.0.3",
    "vite": "^7.2.7"
  }
}
