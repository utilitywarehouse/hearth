{
  "name": "storybook-docs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:docs": "npx wait-on http://localhost:6001 && npx wait-on http://localhost:6002 && npx wait-on http://localhost:6003 && npx wait-on http://localhost:6004 && npx wait-on http://localhost:6005 && pnpm run dev",
    "lint": "eslint .",
    "clean": "rm -rf node_modules storybook-static .turbo",
    "dev": "storybook dev -p 6006 --docs",
    "build:storybook": "storybook build",
    "build:storybook:docs": "storybook build --docs"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-docs": "^10.2.1",
    "@storybook/react-vite": "^10.2.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@utilitywarehouse/hearth-fonts": "workspace:*",
    "@utilitywarehouse/hearth-react": "workspace:*",
    "@utilitywarehouse/hearth-react-icons": "workspace:*",
    "@utilitywarehouse/hearth-tokens": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "globals": "^15.14.0",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.2.10",
    "typescript": "~5.6.2",
    "vite": "^6.4.1",
    "wait-on": "^8.0.3"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
