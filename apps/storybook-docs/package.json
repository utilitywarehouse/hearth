{
  "name": "storybook-docs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:vite": "tsc -b && vite build",
    "sbook-children": "npx concurrently \"npm run storybook -- --config-dir ../storybook-fonts/.storybook --port 6001 --no-open\"  \"npm run storybook -- --config-dir ../storybook-icons/.storybook --port 6002 --no-open\" \"npm run storybook -- --config-dir ../storybook-react/.storybook --port 6003 --no-open\" \"npm run storybook -- --config-dir ../../packages/react-native/.storybook --port 6004 --no-open\"",
    "sbook-parent": "npx wait-on http://localhost:6001 && npx wait-on http://localhost:6002 && npx wait-on http://localhost:6003 && npx wait-on http://localhost:6004 && npm run storybook",
    "sbook": "npx concurrently \"npm run sbook-children\" \"npm run sbook-parent\"",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "rm -rf node_modules storybook-static .turbo",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.3",
    "@eslint/js": "^9.17.0",
    "@storybook/addon-essentials": "^8.6.7",
    "@storybook/addon-interactions": "^8.6.7",
    "@storybook/addon-onboarding": "^8.6.7",
    "@storybook/blocks": "^8.6.7",
    "@storybook/react": "^8.6.7",
    "@storybook/react-vite": "^8.6.7",
    "@storybook/test": "^8.6.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@utilitywarehouse/hearth-css-reset": "workspace:*",
    "@utilitywarehouse/hearth-fonts": "workspace:*",
    "@utilitywarehouse/hearth-react": "workspace:*",
    "@utilitywarehouse/hearth-tokens": "workspace:*",
    "@utilitywarehouse/react-icons": "1.14.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "eslint-plugin-storybook": "^0.11.0",
    "globals": "^15.14.0",
    "storybook": "^8.6.7",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.3"
  },
  "eslintConfig": {
    "extends": [
      "plugin:storybook/recommended"
    ]
  }
}
