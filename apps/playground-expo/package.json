{
  "name": "playground-expo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "scripts": {
    "build:preview:android": "eas build --profile preview -p android --local --output './build/hearth-react-native.apk' --local",
    "build:development:android": "eas build --profile development -p android --local",
    "build:development-sim:android": "eas build --profile development-simulator -p android --local",
    "build:preview:ios": "EAS_LOCAL_BUILD_WORKINGDIR='./eas-build' eas build --profile preview -p ios --local --output './build/hearth-react-native.tar.gz'",
    "build:development:ios": "eas build --profile development -p ios --local",
    "build:development-sim:ios": "eas build --profile development-simulator -p ios --local",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules .turbo"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "5.2.3",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@utilitywarehouse/hearth-react-native": "workspace:^",
    "@utilitywarehouse/hearth-tokens": "workspace:^",
    "expo": "54.0.22",
    "expo-constants": "~18.0.10",
    "expo-dev-client": "6.0.17",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-linking": "~8.0.8",
    "expo-router": "6.0.14",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-web-browser": "~15.0.9",
    "expo-xml-font": "^3.0.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-edge-to-edge": "1.6.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-nitro-modules": "0.31.4",
    "react-native-reanimated": "4.1.3",
    "react-native-safe-area-context": "5.6.1",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-unistyles": "3.0.17",
    "react-native-web": "^0.21.1",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
