{
  "name": "@utilitywarehouse/hearth-react-native-expo",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build:preview:android": "eas build --profile preview -p android --local --output './build/hearth-react-native.apk' --local",
    "build:development:android": "eas build --profile development -p android --local",
    "build:development-sim:android": "eas build --profile development-simulator -p android --local",
    "build:preview:ios": "EAS_LOCAL_BUILD_WORKINGDIR='./eas-build' eas build --profile preview -p ios --local --output './build/hearth-react-native.tar.gz'",
    "build:development:ios": "eas build --profile development -p ios --local",
    "build:development-sim:ios": "eas build --profile development-simulator -p ios --local",
    "eas-build-pre-install": "echo '//registry.npmjs.org/:_authToken=${NPM_TOKEN}' > temp.txt && echo 'registry=https://registry.npmjs.org/' >> temp.txt && cat ../../.npmrc >> temp.txt && mv temp.txt ../../.npmrc",
    "eas-build-post-install": "if [[ \"$OSTYPE\" == \"darwin\"* ]]; then sed -i '.bak' '/\\/\\/registry.npmjs.org\\/:_authToken=${NPM_TOKEN}/d' ../../.npmrc && sed -i '.bak' '/registry=https:\\/\\/registry.npmjs.org\\//d' ../../.npmrc && rm ../../.npmrc.bak; else sed -i '/\\/\\/registry.npmjs.org\\/:_authToken=${NPM_TOKEN}/d' ../../.npmrc && sed -i '/registry=https:\\/\\/registry.npmjs.org\\//d' ../../.npmrc; fi",
    "build-storybook": "storybook build",
    "storybook-generate": "sb-rn-get-stories -js",
    "storybook": "cross-env STORYBOOK_ENABLED='true' expo start ",
    "storybook:ios": "cross-env STORYBOOK_ENABLED='true' expo start --ios",
    "storybook:android": "cross-env STORYBOOK_ENABLED='true' expo start --android",
    "clean": "rm -rf node_modules storybook-static .turbo"
  },
  "dependencies": {
    "@expo/metro-runtime": "6.0.0-canary-20250722-599a28f",
    "@expo/vector-icons": "^14.1.0",
    "@gorhom/bottom-sheet": "^5.1.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.3.0",
    "@react-native-community/slider": "4.5.6",
    "@storybook/addon-ondevice-actions": "9.0.9",
    "@storybook/addon-ondevice-controls": "9.0.9",
    "@storybook/react-native": "9.0.9",
    "@types/react": "~19.0.14",
    "@utilitywarehouse/colour-system": "^0.5.0",
    "@utilitywarehouse/hearth-react-native": "workspace:^",
    "@utilitywarehouse/hearth-tokens": "workspace:^",
    "expo": "54.0.0-canary-20250722-599a28f",
    "expo-constants": "17.1.8-canary-20250722-599a28f",
    "expo-dev-client": "5.1.9-canary-20250722-599a28f",
    "expo-font": "13.4.0-canary-20250722-599a28f",
    "expo-splash-screen": "0.30.11-canary-20250722-599a28f",
    "expo-xml-font": "^3.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.80.0",
    "react-native-edge-to-edge": "1.6.0",
    "react-native-gesture-handler": "2.26.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-nitro-modules": "^0.26.4",
    "react-native-reanimated": "3.18.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-svg": "15.12.0",
    "react-native-unistyles": "3.0.7",
    "react-native-web": "^0.20.0",
    "storybook": "^9.0.17"
  },
  "devDependencies": {
    "@babel/core": "7.26.10",
    "babel-loader": "^9.1.3",
    "cross-env": "^7.0.3",
    "eas-cli": "^16.9.0",
    "eslint-plugin-storybook": "9.0.17",
    "typescript": "5.7.3"
  }
}
