{
  "name": "@utilitywarehouse/hearth-react-native-expo",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build:preview:android": "eas build --profile preview -p android --local --output './build/hearth-react-native.apk'",
    "build:development:android": "eas build --profile development -p android",
    "build:development-sim:android": "eas build --profile development-simulator -p android",
    "build:preview:ios": "mv ./app.config.ts ./app.config.android.ts && mv ./app.config.ios.ts ./app.config.ts && EAS_LOCAL_BUILD_WORKINGDIR='./eas-build' eas build --profile preview -p ios --local --output './build/hearth-react-native.tar.gz' && mv ./app.config.ts ./app.config.ios.ts && mv ./app.config.android.ts ./app.config.ts",
    "build:development:ios": "eas build --profile development -p ios",
    "build:development-sim:ios": "eas build --profile development-simulator -p ios",
    "eas-build-pre-install": "echo '//registry.npmjs.org/:_authToken=${NPM_TOKEN}' > temp.txt && echo 'registry=https://registry.npmjs.org/' >> temp.txt && cat ../../.npmrc >> temp.txt && mv temp.txt ../../.npmrc",
    "eas-build-post-install": "if [[ \"$OSTYPE\" == \"darwin\"* ]]; then sed -i '.bak' '/\\/\\/registry.npmjs.org\\/:_authToken=${NPM_TOKEN}/d' ../../.npmrc && sed -i '.bak' '/registry=https:\\/\\/registry.npmjs.org\\//d' ../../.npmrc && rm ../../.npmrc.bak; else sed -i '/\\/\\/registry.npmjs.org\\/:_authToken=${NPM_TOKEN}/d' ../../.npmrc && sed -i '/registry=https:\\/\\/registry.npmjs.org\\//d' ../../.npmrc; fi",
    "build-storybook": "storybook build",
    "storybook-generate": "sb-rn-get-stories -js",
    "storybook": "cross-env STORYBOOK_ENABLED='true' expo start ",
    "storybook:ios": "cross-env STORYBOOK_ENABLED='true' expo start --ios",
    "storybook:android": "cross-env STORYBOOK_ENABLED='true' expo start --android",
    "clean": "rm -rf node_modules storybook-static .turbo",
    "postinstall": "node ./scripts/postinstall.js"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@expo/vector-icons": "^14.0.3",
    "@gorhom/bottom-sheet": "^5.0.6",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/datetimepicker": "8.2.0",
    "@react-native-community/slider": "4.5.5",
    "@storybook/addon-ondevice-actions": "8.5.3",
    "@storybook/addon-ondevice-controls": "8.5.3",
    "@storybook/react-native": "8.5.3",
    "@types/react": "~18.3.12",
    "@utilitywarehouse/colour-system": "^0.5.0",
    "@utilitywarehouse/hearth-react-native": "workspace:^",
    "@utilitywarehouse/hearth-tokens": "workspace:^",
    "expo": "^52.0.30",
    "expo-constants": "~17.0.5",
    "expo-dev-client": "~5.0.11",
    "expo-font": "^13.0.3",
    "expo-xml-font": "^3.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.6",
    "react-native-edge-to-edge": "1.4.3",
    "react-native-gesture-handler": "2.20.2",
    "react-native-markdown-display": "^7.0.2",
    "react-native-nitro-modules": "^0.21.0",
    "react-native-reanimated": "~3.16.5",
    "react-native-safe-area-context": "4.12.0",
    "react-native-svg": "15.8.0",
    "react-native-unistyles": "3.0.0-beta.6",
    "react-native-web": "^0.19.10"
  },
  "devDependencies": {
    "@babel/core": "7.26.7",
    "babel-loader": "^9.1.3",
    "cross-env": "^7.0.3",
    "typescript": "5.7.3"
  }
}
