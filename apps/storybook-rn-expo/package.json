{
  "name": "hearth-react-native-expo",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build:preview:android": "eas build --profile preview -p android --local --output './build/hearth-react-native.apk' --local",
    "build:development:android": "eas build --profile development -p android --local",
    "build:development-sim:android": "eas build --profile development-simulator -p android --local",
    "build:preview:ios": "EAS_LOCAL_BUILD_WORKINGDIR='./eas-build' eas build --profile preview -p ios --local --output './build/hearth-react-native.tar.gz'",
    "build:development:ios": "eas build --profile development -p ios --local",
    "build:development-sim:ios": "eas build --profile development-simulator -p ios --local",
    "eas-build-pre-install": "echo '//registry.npmjs.org/:_authToken=${NPM_TOKEN}' > temp.txt && echo 'registry=https://registry.npmjs.org/' >> temp.txt && cat ../../.npmrc >> temp.txt && mv temp.txt ../../.npmrc",
    "eas-build-post-install": "if [[ \"$OSTYPE\" == \"darwin\"* ]]; then sed -i '.bak' '/\\/\\/registry.npmjs.org\\/:_authToken=${NPM_TOKEN}/d' ../../.npmrc && sed -i '.bak' '/registry=https:\\/\\/registry.npmjs.org\\//d' ../../.npmrc && rm ../../.npmrc.bak; else sed -i '/\\/\\/registry.npmjs.org\\/:_authToken=${NPM_TOKEN}/d' ../../.npmrc && sed -i '/registry=https:\\/\\/registry.npmjs.org\\//d' ../../.npmrc; fi",
    "prebuild": "expo prebuild --clean",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "clean": "rm -rf node_modules storybook-static .turbo"
  },
  "dependencies": {
    "@expo/metro-runtime": "6.1.1",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "5.2.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/slider": "5.0.1",
    "@storybook/addon-ondevice-actions": "9.1.1",
    "@storybook/addon-ondevice-controls": "9.1.1",
    "@storybook/react-native": "9.1.1",
    "@types/react": "~19.1.11",
    "@utilitywarehouse/hearth-react-native": "workspace:^",
    "@utilitywarehouse/hearth-react-native-icons": "workspace:^",
    "@utilitywarehouse/hearth-tokens": "workspace:^",
    "expo": "54.0.0-preview.12",
    "expo-constants": "18.0.6",
    "expo-dev-client": "6.0.7",
    "expo-font": "14.0.6",
    "expo-splash-screen": "31.0.7",
    "expo-xml-font": "^3.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "0.81.1",
    "react-native-edge-to-edge": "1.6.1",
    "react-native-gesture-handler": "2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-nitro-modules": "^0.28.0",
    "react-native-reanimated": "4.0.2",
    "react-native-safe-area-context": "5.6.1",
    "react-native-svg": "15.12.1",
    "react-native-unistyles": "3.0.10",
    "react-native-web": "^0.21.1",
    "react-native-worklets": "0.4.2",
    "storybook": "^9.1.6"
  },
  "devDependencies": {
    "@babel/core": "7.26.10",
    "babel-loader": "^9.1.3",
    "cross-env": "^7.0.3",
    "eas-cli": "^16.9.0",
    "eslint-plugin-storybook": "9.1.6",
    "typescript": "5.9.2"
  }
}
