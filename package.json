{
  "name": "root",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utilitywarehouse/hearth.git"
  },
  "scripts": {
    "setup": "corepack enable && corepack prepare pnpm@11.0.5 --activate && pnpm install",
    "refresh": "pnpm clean && pnpm install && pnpm run build",
    "clean": "turbo run clean --concurrency=20 && rm -rf node_modules",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:assets": "turbo run build:storybook --filter=storybook-docs",
    "build:css-reset": "turbo run build --filter=@utilitywarehouse/hearth-css-reset",
    "build:fonts": "turbo run build:storybook --filter=storybook-fonts",
    "build:react": "turbo run build --filter=@utilitywarehouse/hearth-react",
    "build:react-native": "turbo run build:storybook --filter=@utilitywarehouse/hearth-react-native",
    "build:storybook": "turbo build build:storybook",
    "build:storybook:docs": "turbo build:storybook:docs",
    "build:storybook:react": "turbo run build:storybook --filter=@utilitywarehouse/hearth-react -- -o \"./storybook-static\"",
    "build:tokens": "turbo run @utilitywarehouse/hearth-tokens#build:tokens",
    "lint": "turbo run lint:fix --filter='./packages/*'",
    "lint:ci": "turbo run lint:ci --filter='./packages/*'",
    "checks": "pnpm run lint && pnpm run format",
    "checks:ci": "pnpm run lint:ci && pnpm run format:ci",
    "changeset": "changeset",
    "ci:publish": "pnpm run build:packages && changeset publish",
    "ci:version": "changeset version && turbo run copy:changelog generate:llm-docs && pnpm install --no-frozen-lockfile",
    "dev:docs": "turbo run dev:docs",
    "dev:fonts": "turbo run @utilitywarehouse/hearth-fonts#dev storybook-fonts#dev",
    "dev:react": "turbo run dev --filter=@utilitywarehouse/hearth-react",
    "dev:react-native": "turbo run @utilitywarehouse/hearth-react-native#dev",
    "dev:react-native:android": "turbo run hearth-react-native-expo#android",
    "dev:react-native:ios": "turbo run hearth-react-native-expo#ios",
    "dev:react-native:prebuild": "turbo run hearth-react-native-expo#prebuild",
    "test:react-native": "turbo run test --filter=@utilitywarehouse/hearth-react-native && pnpm test:react-native:storybook",
    "test:react-native:storybook": "pnpm --dir packages/react-native run test:storybook",
    "test:react": "pnpm --dir packages/react run test:storybook",
    "format": "prettier --write README.md AGENTS.md CODE_OF_CONDUCT.md && turbo run format",
    "format:ci": "prettier --check README.md AGENTS.md CODE_OF_CONDUCT.md && turbo run format:ci",
    "generate:react": "turbo run @utilitywarehouse/hearth-react-icons#generate @utilitywarehouse/hearth-react-native-icons#generate",
    "generate:icons": "pnpm run generate:svg-icons && pnpm run generate:react && pnpm run generate:storybook:icons && pnpm run format && cat ./updated-icons.md && rm ./updated-icons.md",
    "generate:json-assets": "turbo run @utilitywarehouse/hearth-json-assets#generate && pnpm run generate:storybook:assets && pnpm run format && cat ./updated-json-assets.md && rm ./updated-json-assets.md",
    "generate:json-assets:ci": "turbo run @utilitywarehouse/hearth-json-assets#generate && turbo run storybook-docs#generate:assets",
    "generate:storybook:assets": "turbo run storybook-docs#generate:assets",
    "generate:storybook:icons": "turbo run storybook-docs#generate:icons",
    "generate:svg-assets": "turbo run @utilitywarehouse/hearth-svg-assets#generate && turbo run storybook-docs#generate:assets",
    "generate:svg-icons": "turbo run @utilitywarehouse/hearth-svg-icons#generate",
    "generate:tokens:react": "turbo run build:tokens && turbo run @utilitywarehouse/hearth-react#copy:tokens",
    "generate:llm-docs": "pnpm --dir packages/react run generate:llm-docs"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "pnpm": "11.0.5"
  },
  "prettier": "@utilitywarehouse/prettier-config",
  "packageManager": "pnpm@11.0.5+sha512.94fa09e72016402aefce788e46994e18eb1922998b16b6fd5aa6bafd8ae4dea05d0852f60247fdb7d5ab8199a7b0beda830398f3f80cb9f822398522a1535481",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "zod-validation-error": "^4.0.2"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-react>eslint": "10",
        "eslint-plugin-jsx-a11y>eslint": "10"
      }
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.9",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@figma/code-connect": "^1.3.12",
    "@utilitywarehouse/prettier-config": "^0.1.1",
    "chromatic": "^17.5.0",
    "eslint": "^10.4.1",
    "zod-validation-error": "^4.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-storybook": "^10.4.3",
    "prettier": "^3.8.3",
    "turbo": "^2.9.12",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.61.0"
  }
}
