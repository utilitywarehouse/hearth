{
  "name": "root",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utilitywarehouse/hearth.git"
  },
  "scripts": {
    "setup": "corepack enable && corepack prepare pnpm@10.28.2 --activate && pnpm install --loglevel=\"info\" && pnpm build",
    "refresh": "pnpm clean && pnpm install --loglevel=\"info\" && pnpm run build",
    "clean": "pnpm -r --stream --loglevel=\"info\" clean && rm -rf node_modules",
    "build": "turbo build",
    "build:assets": "turbo run @utilitywarehouse/hearth-react#build @utilitywarehouse/hearth-fonts#build @utilitywarehouse/hearth-css-reset#build storybook-assets#build:storybook",
    "build:css-reset": "turbo run @utilitywarehouse/hearth-css-reset#build",
    "build:fonts": "turbo run @utilitywarehouse/hearth-fonts#build storybook-fonts#build:storybook",
    "build:icons": "turbo run @utilitywarehouse/hearth-react#build @utilitywarehouse/hearth-fonts#build @utilitywarehouse/hearth-css-reset#build storybook-icons#build:storybook",
    "build:react": "turbo run @utilitywarehouse/hearth-react#build @utilitywarehouse/hearth-fonts#build @utilitywarehouse/hearth-css-reset#build @utilitywarehouse/hearth-tokens#build @utilitywarehouse/hearth-react-icons#build",
    "build:react-native": "turbo run @utilitywarehouse/hearth-react-native#build @utilitywarehouse/hearth-react-native#build:storybook",
    "build:storybook": "turbo build build:storybook",
    "build:storybook:docs": "turbo build build:storybook:docs",
    "build:storybook:react": "turbo run --filter=storybook-react build:storybook -- -o \"./storybook-static\"",
    "build:tokens": "turbo run  storybook-tokens#build:storybook",
    "changeset": "changeset",
    "checks": "turbo run format lint:fix --filter='./packages/*'",
    "checks:build": "turbo run format lint:fix build --filter='./packages/*'",
    "checks:ci": "turbo run format:ci lint --filter='./packages/*'",
    "ci:publish": "pnpm run build && changeset publish",
    "ci:version": "changeset version && turbo run copy:changelog && pnpm install --no-frozen-lockfile",
    "copy-tokens:react": "rm -rf ./packages/react/src/styles/tokens && cp -r ./packages/tokens/css ./packages/react/src/styles/tokens",
    "dev:docs": "turbo run dev:docs",
    "dev:fonts": "turbo run @utilitywarehouse/hearth-fonts#dev storybook-fonts#dev",
    "dev:react": "turbo run @utilitywarehouse/hearth-react#dev storybook-react#dev",
    "dev:react-native": "turbo run @utilitywarehouse/hearth-react-native#dev @utilitywarehouse/hearth-react-native#dev",
    "dev:react-native:android": "turbo run hearth-react-native-expo#android",
    "dev:react-native:ios": "turbo run hearth-react-native-expo#ios",
    "dev:react-native:prebuild": "turbo run hearth-react-native-expo#prebuild",
    "format": "turbo run format",
    "format:ci": "turbo run format:ci",
    "generate:react": "turbo run @utilitywarehouse/hearth-react-icons#generate @utilitywarehouse/hearth-react-native-icons#generate",
    "generate:icons": "pnpm run generate:svg-icons && pnpm run generate:react && pnpm run generate:storybook:icons && pnpm run format && cat ./updated-icons.md && rm ./updated-icons.md",
    "generate:json-assets": "turbo run @utilitywarehouse/hearth-json-assets#generate && pnpm run generate:storybook:assets && pnpm run format && cat ./updated-json-assets.md && rm ./updated-json-assets.md",
    "generate:json-assets:ci": "turbo run @utilitywarehouse/hearth-json-assets#generate && turbo run generate:storybook:assets",
    "generate:storybook:assets": "turbo run storybook-assets#generate",
    "generate:storybook:icons": "turbo run storybook-icons#generate",
    "generate:svg-assets": "turbo run @utilitywarehouse/hearth-svg-assets#generate && turbo run storybook-assets#generate",
    "generate:svg-icons": "turbo run @utilitywarehouse/hearth-svg-icons#generate",
    "generate:tokens": "turbo run @utilitywarehouse/hearth-tokens#build",
    "generate:tokens:react": "pnpm run generate:tokens && pnpm run copy-tokens:react && turbo run @utilitywarehouse/hearth-react#copy-tokens-index",
    "lint": "turbo run lint --filter='./packages/*'",
    "lint:fix": "turbo run lint:fix --filter='./packages/*'"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "pnpm": "10.28.2"
  },
  "prettier": "@utilitywarehouse/prettier-config",
  "packageManager": "pnpm@10.28.2",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    },
    "patchedDependencies": {
      "react-native-worklets@0.5.1": "patches/react-native-worklets@0.5.1.patch"
    },
    "onlyBuiltDependencies": [
      "@bundled-es-modules/glob",
      "dtrace-provider",
      "esbuild",
      "react-native-nitro-modules",
      "sharp",
      "style-dictionary",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.9",
    "@figma/code-connect": "^1.3.12",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@utilitywarehouse/prettier-config": "^0.1.1",
    "chromatic": "^13.3.0",
    "eslint": "8",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
